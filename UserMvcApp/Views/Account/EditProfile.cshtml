@model UserMvcApp.ViewModels.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile"; Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Edit Profile</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
        <div class="card shadow p-4" style="width:460px">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Edit Profile</h4>
                <a asp-action="Logout" class="btn btn-outline-danger btn-sm">Logout</a>
            </div>

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success">@ViewBag.Success</div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-action="EditProfile" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <h6 class="text-muted mb-3">Basic Info</h6>

                <div class="mb-3">
                    <label class="form-label">Current Email</label>
                    <input value="@Model.Email" class="form-control" disabled />
                </div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                </div>

                <hr />
                <h6 class="text-muted mb-3">Change Email (optional)</h6>

                <div class="mb-3">
                    <label asp-for="NewEmail" class="form-label"></label>
                    <input asp-for="NewEmail" class="form-control" placeholder="Leave blank to keep current" />
                    <span asp-validation-for="NewEmail" class="text-danger small"></span>
                </div>

                <hr />
                <h6 class="text-muted mb-3">Change Password (optional)</h6>

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label"></label>
                    <input asp-for="CurrentPassword" class="form-control" placeholder="Required to change password" />
                </div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Leave blank to keep current" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Save Changes</button>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>