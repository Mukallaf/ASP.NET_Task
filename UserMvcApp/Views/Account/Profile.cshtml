@model UserMvcApp.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Account"; Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>My Account</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
        <div class="card shadow p-4" style="width:460px">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">My Account</h4>
                <a asp-action="Logout" class="btn btn-outline-danger btn-sm">Logout</a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <!-- Profile Avatar -->
            <div class="text-center mb-4">
                <div style="width:80px;height:80px;border-radius:50%;background:#0d6efd;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                    <span style="color:white;font-size:32px;font-weight:500;">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </span>
                </div>
                <h5 class="mt-2 mb-0">@Model.FullName</h5>
                <small class="text-muted">Member since @Model.CreatedAt.ToString("MMM yyyy")</small>
            </div>

            <!-- Info Cards -->
            <div class="mb-3 p-3 bg-light rounded">
                <small class="text-muted d-block">Full Name</small>
                <span class="fw-500">@Model.FullName</span>
            </div>
            <div class="mb-3 p-3 bg-light rounded">
                <small class="text-muted d-block">Email</small>
                <span>@Model.Email</span>
            </div>
            <div class="mb-3 p-3 bg-light rounded">
                <small class="text-muted d-block">Phone</small>
                <span>@Model.Phone</span>
            </div>

            <!-- Edit Button -->
            <a asp-action="EditProfile" class="btn btn-primary w-100 mt-2">
                Edit Profile
            </a>

        </div>
    </div>
</body>
</html>